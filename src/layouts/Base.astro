---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = '大阪市の車庫証明・パスポート申請代行は千代行政書士法務事務所へ。2つの面倒な手続きを、ひとりの行政書士にまとめてお任せいただけます。',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <StickyCta />
  </body>
</html>
