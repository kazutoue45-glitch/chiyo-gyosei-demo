---
const base = import.meta.env.BASE_URL;
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = 'まずは、お気軽にご相談ください',
  text = '「自分のケースだと料金は？」「何を用意すればいい？」そんな段階からで構いません。平日に動けない分は、こちらで代わります。',
} = Astro.props;
---

<section class="cta">
  <div class="cta__inner container-narrow">
    <p class="cta__label eng">Contact</p>
    <h2 class="cta__head">{heading}</h2>
    <p class="cta__text">{text}</p>
    <div class="cta__actions">
      <a class="btn btn-accent btn-lg" href={`${base}contact`}>お問い合わせフォーム</a>
      <a class="cta__tel" href="tel:0663536079">
        <span class="cta__tel-label">お電話でのご相談</span>
        <span class="tel-num">06-6353-6079</span>
        <span class="cta__tel-hours">平日 10:00〜17:30</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta { background: linear-gradient(135deg, var(--navy) 0%, var(--passport) 140%); color: #fff; padding-block: 72px; text-align: center; }
  .cta__label { font-size: 0.82rem; letter-spacing: 0.24em; text-transform: uppercase; color: #9fd0f0; }
  .cta__head { font-size: 1.55rem; margin: 10px 0 18px; color: #fff; }
  .cta__text { font-size: 0.95rem; line-height: 1.9; color: rgba(255,255,255,.88); margin-bottom: 32px; }
  .cta__actions { display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .cta__tel { display: flex; flex-direction: column; align-items: center; color: #fff; }
  .cta__tel-label { font-size: 0.78rem; color: rgba(255,255,255,.8); }
  .cta__tel .tel-num { font-size: 2rem; line-height: 1.2; }
  .cta__tel-hours { font-size: 0.78rem; color: rgba(255,255,255,.8); }
  @media (min-width: 768px) {
    .cta__head { font-size: 2rem; }
    .cta__actions { flex-direction: row; justify-content: center; gap: 40px; }
  }
</style>
